<?xml version="1.0" encoding="utf-8"?>
<!-- Checkout item row with a separate controls row -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md"
    android:background="@drawable/bg_checkout_item"
    android:orientation="vertical"
    android:padding="@dimen/spacing_md">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_product_image"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_food_image"
            android:contentDescription="@string/cd_food_image"
            android:scaleType="centerCrop"
            tools:src="@drawable/img_burger" />

        <LinearLayout
            android:id="@+id/ll_product_details"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_lg"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_product_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="sans-serif-black"
                android:maxLines="1"
                android:textColor="@color/navy"
                android:textSize="16sp"
                tools:text="Gourmet Burger" />

            <TextView
                android:id="@+id/tv_product_customization"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif"
                android:maxLines="1"
                android:textColor="@color/grey_text"
                android:textSize="@dimen/text_size_body"
                tools:text="Extra cheese, No onions" />

            <TextView
                android:id="@+id/tv_product_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_size_subhead"
                tools:text="$12.00" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_quantity_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:gravity="end|center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_minus_quantity"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:minWidth="40dp"
            android:minHeight="40dp"
                android:text="@string/quantity_minus"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:contentDescription="@string/remove_one_item" />

        <TextView
            android:id="@+id/tv_quantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_quantity_badge"
            android:fontFamily="sans-serif-medium"
            android:minWidth="40dp"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_sm"
            android:textAlignment="center"
            android:textColor="@color/grey_text"
            android:textSize="@dimen/text_size_body"
            tools:text="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_plus_quantity"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:minWidth="40dp"
            android:minHeight="40dp"
                android:text="@string/quantity_plus"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:contentDescription="@string/add_one_item" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_remove_item"
            style="@style/Widget.QuickBite.Button.ViewCart"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:minWidth="0dp"
            android:paddingHorizontal="12dp"
            android:text="@string/remove_item"
            android:textAllCaps="false"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>
