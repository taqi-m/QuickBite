<?xml version="1.0" encoding="utf-8"?>
<!-- L7: TableRow for order history item -->
<TableRow xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:paddingTop="@dimen/spacing_lg"
    android:paddingBottom="@dimen/spacing_lg">

    <!-- Date Column -->
    <TextView
        android:id="@+id/tv_order_date"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.3"
        android:fontFamily="sans-serif"
        android:paddingStart="0dp"
        android:paddingEnd="@dimen/spacing_sm"
        android:textColor="@color/grey_text"
        android:textSize="@dimen/text_size_body"
        tools:text="Oct 24, 2023" />

    <!-- Restaurant Details Column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.5"
        android:orientation="vertical"
        android:paddingStart="0dp"
        android:paddingEnd="@dimen/spacing_sm">

        <TextView
            android:id="@+id/tv_restaurant_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:textColor="@color/navy"
            android:textSize="@dimen/text_size_body"
            tools:text="Artisan Pizza Hub" />

        <TextView
            android:id="@+id/tv_order_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif"
            android:textColor="@color/grey_text"
            android:textSize="12sp"
            tools:text="3 items • Delivered" />
    </LinearLayout>

    <!-- Total Column -->
    <TextView
        android:id="@+id/tv_order_total"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.2"
        android:fontFamily="sans-serif-bold"
        android:gravity="end"
        android:textColor="@color/primary"
        android:textSize="@dimen/text_size_body"
        tools:text="$42.50" />
</TableRow>


