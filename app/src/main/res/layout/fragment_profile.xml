<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_light_background"
    android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorDivider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingTop="@dimen/spacing_xl">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="2dp"
                app:strokeColor="@color/widget_border_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_xl">

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/iv_profile_avatar"
                            android:layout_width="@dimen/profile_avatar_size"
                            android:layout_height="@dimen/profile_avatar_size"
                            android:background="@drawable/bg_profile_avatar"
                            android:contentDescription="@string/cd_profile_picture"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_profile" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tv_profile_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/profile_name"
                        android:textColor="@color/navy"
                        android:textSize="24sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.15"
                android:paddingHorizontal="@dimen/spacing_xs"
                android:text="@string/account_settings"
                android:textAllCaps="true"
                android:textColor="@color/grey_text"
                android:textSize="@dimen/text_size_caption" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="2dp"
                app:strokeColor="@color/widget_border_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/menu_personal_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_menu_item"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/spacing_lg"
                        android:paddingVertical="@dimen/spacing_lg">

                        <ImageView
                            android:layout_width="@dimen/icon_size_medium"
                            android:layout_height="@dimen/icon_size_medium"
                            android:contentDescription="@string/personal_information"
                            android:src="@drawable/ic_person_128"
                            app:tint="@color/primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_lg"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/personal_information"
                            android:textColor="@color/navy"
                            android:textSize="@dimen/text_size_subhead" />

                        <ImageView
                            android:layout_width="@dimen/icon_size_medium"
                            android:layout_height="@dimen/icon_size_medium"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right_128"
                            app:tint="@color/grey_text" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/spacing_lg"
                        android:background="@color/widget_border_light" />

                    <LinearLayout
                        android:id="@+id/menu_addresses"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_menu_item"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/spacing_lg"
                        android:paddingVertical="@dimen/spacing_lg">

                        <ImageView
                            android:layout_width="@dimen/icon_size_medium"
                            android:layout_height="@dimen/icon_size_medium"
                            android:contentDescription="@string/manage_addresses"
                            android:src="@drawable/ic_location_on_128"
                            app:tint="@color/primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_lg"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/manage_addresses"
                            android:textColor="@color/navy"
                            android:textSize="@dimen/text_size_subhead" />

                        <ImageView
                            android:layout_width="@dimen/icon_size_medium"
                            android:layout_height="@dimen/icon_size_medium"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right_128"
                            app:tint="@color/grey_text" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/spacing_lg"
                        android:background="@color/widget_border_light" />

                    <LinearLayout
                        android:id="@+id/menu_payment_methods"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_menu_item"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/spacing_lg"
                        android:paddingVertical="@dimen/spacing_lg">

                        <ImageView
                            android:layout_width="@dimen/icon_size_medium"
                            android:layout_height="@dimen/icon_size_medium"
                            android:contentDescription="@string/payment_methods_menu"
                            android:src="@drawable/ic_payment_128"
                            app:tint="@color/primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_lg"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/payment_methods_menu"
                            android:textColor="@color/navy"
                            android:textSize="@dimen/text_size_subhead" />

                        <ImageView
                            android:layout_width="@dimen/icon_size_medium"
                            android:layout_height="@dimen/icon_size_medium"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right_128"
                            app:tint="@color/grey_text" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.15"
                android:paddingHorizontal="@dimen/spacing_xs"
                android:text="@string/preferences"
                android:textAllCaps="true"
                android:textColor="@color/grey_text"
                android:textSize="@dimen/text_size_caption" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="2dp"
                app:strokeColor="@color/widget_border_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/spacing_lg"
                        android:paddingVertical="@dimen/spacing_lg">

                        <ImageView
                            android:id="@+id/icon_notifications"
                            android:layout_width="@dimen/icon_size_medium"
                            android:layout_height="@dimen/icon_size_medium"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:contentDescription="@string/push_notifications"
                            android:src="@drawable/ic_notifications_128"
                            app:tint="@color/primary" />

                        <LinearLayout
                            android:id="@+id/text_container_notifications"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="@dimen/spacing_lg"
                            android:layout_toEndOf="@id/icon_notifications"
                            android:layout_toStartOf="@id/switch_notifications"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/push_notifications"
                                android:textColor="@color/navy"
                                android:textSize="@dimen/text_size_subhead" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="sans-serif"
                                android:text="@string/push_notifications_subtitle"
                                android:textColor="@color/grey_text"
                                android:textSize="@dimen/text_size_caption" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_notifications"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:checked="true"
                            app:thumbTint="@color/white"
                            app:trackTint="@color/primary" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/spacing_lg"
                        android:background="@color/widget_border_light" />

                    <LinearLayout
                        android:id="@+id/menu_language"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_menu_item"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/spacing_lg"
                        android:paddingVertical="@dimen/spacing_lg">

                        <ImageView
                            android:layout_width="@dimen/icon_size_medium"
                            android:layout_height="@dimen/icon_size_medium"
                            android:contentDescription="@string/language"
                            android:src="@drawable/ic_language_128"
                            app:tint="@color/primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_lg"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/language"
                            android:textColor="@color/navy"
                            android:textSize="@dimen/text_size_subhead" />

                        <TextView
                            android:id="@+id/tv_language_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:fontFamily="sans-serif"
                            android:text="@string/language_value"
                            android:textColor="@color/grey_text"
                            android:textSize="@dimen/text_size_body" />

                        <ImageView
                            android:layout_width="@dimen/icon_size_medium"
                            android:layout_height="@dimen/icon_size_medium"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right_128"
                            app:tint="@color/grey_text" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/spacing_lg"
                        android:background="@color/widget_border_light" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/spacing_lg"
                        android:paddingVertical="@dimen/spacing_lg">

                        <ImageView
                            android:id="@+id/icon_dark_mode"
                            android:layout_width="@dimen/icon_size_medium"
                            android:layout_height="@dimen/icon_size_medium"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:contentDescription="@string/dark_mode"
                            android:src="@drawable/ic_dark_mode_128"
                            app:tint="@color/primary" />

                        <TextView
                            android:id="@+id/tv_dark_mode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="@dimen/spacing_lg"
                            android:layout_toEndOf="@id/icon_dark_mode"
                            android:layout_toStartOf="@id/switch_dark_mode"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/dark_mode"
                            android:textColor="@color/navy"
                            android:textSize="@dimen/text_size_subhead" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_dark_mode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:checked="false"
                            app:thumbTint="@color/white"
                            app:trackTint="@color/md_theme_light_surfaceVariant" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sign_out"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:fontFamily="sans-serif-black"
                android:paddingVertical="@dimen/spacing_lg"
                android:text="@string/sign_out"
                android:textAllCaps="false"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_size_subhead"
                app:backgroundTint="@color/white"
                app:cornerRadius="@dimen/corner_radius_lg"
                app:icon="@drawable/ic_logout_128"
                app:iconGravity="textStart"
                app:iconPadding="@dimen/spacing_sm"
                app:iconTint="@color/primary"
                app:strokeColor="@color/widget_border_light"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>