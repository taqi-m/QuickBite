<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Material Design 3 Base Theme -->
    <style name="Theme.QuickBite" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>

        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/md_theme_light_background</item>
        <item name="colorOnBackground">@color/md_theme_light_onBackground</item>
        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_light_onSurfaceVariant</item>

        <!-- System UI -->
        <item name="android:statusBarColor">@color/navy</item>
        <item name="android:navigationBarColor">@color/md_theme_light_surface</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Legacy Support -->
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="android:windowBackground">@color/md_theme_light_background</item>
    </style>

    <!-- Widget Styles -->
    <style name="Widget.QuickBite.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/corner_radius_card</item>
        <item name="cardElevation">@dimen/elevation_card</item>
        <item name="cardBackgroundColor">@color/widget_surface_light</item>
    </style>

    <style name="Widget.QuickBite.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/corner_radius_md</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>



    <style name="Widget.QuickBite.Button.InversePrimary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/white</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">@dimen/corner_radius_md</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.QuickBite.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">@dimen/corner_radius_chip</item>
        <item name="chipBackgroundColor">@color/colorChipBackground</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/primary</item>
        <item name="chipStrokeColor">@android:color/transparent</item>
        <item name="chipStrokeWidth">0dp</item>
    </style>

    <style name="Widget.QuickBite.Chip.Selected" parent="Widget.QuickBite.Chip">
        <item name="chipBackgroundColor">@color/primary</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.QuickBite.Button.ViewCart" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary_dark</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/corner_radius_lg</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="elevation">@dimen/elevation_fab</item>
    </style>

    <!-- Text Styles -->
    <style name="TextAppearance.QuickBite.Headline" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">@color/md_theme_light_onBackground</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.QuickBite.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:textColor">@color/md_theme_light_onBackground</item>
    </style>

    <style name="TextAppearance.QuickBite.SectionHeader" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">@dimen/text_size_caption</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">@color/md_theme_light_onSurfaceVariant</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="TextAppearance.QuickBite.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/md_theme_light_onSurface</item>
    </style>

    <style name="TextAppearance.QuickBite.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">@dimen/text_size_tiny</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/md_theme_light_onSurfaceVariant</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>